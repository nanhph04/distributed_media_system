@startuml
title Thiết kế database Finance Service - Event và chống trùng

left to right direction

skinparam TitleFontSize 40
skinparam defaultFontSize 28
skinparam ArrowFontSize 26
skinparam ClassFontSize 28
skinparam ClassAttributeFontSize 27
skinparam ClassHeaderFontSize 30
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 70
hide circle

entity "payment_outbox" as outbox {
  * id : uuid <<PK>>
  --
  * event_id : varchar(128) <<UQ>>
  * topic : varchar(128)
  * payload : jsonb
  * status : enum(pending, published, failed)
  * retry_count : integer
  last_error : text
  published_at : timestamptz
  * created_at : timestamptz
  * updated_at : timestamptz
}

entity "processed_wallet_events" as processed {
  * event_id : varchar(128) <<PK>>
  --
  * processed_at : timestamptz
  * created_at : timestamptz
}

entity "payment_idempotency_records" as idem {
  * id : uuid <<PK>>
  --
  * user_id : varchar(128)
  * idempotency_key : varchar(255)
  * request_hash : varchar(64)
  * response : jsonb
}

note bottom of outbox
  Lưu event cần publish:
  membership.payment.success,
  video.payment.success,
  membership.auto_renew.failed...
end note

note bottom of processed
  Lưu event đã consume:
  user.status.changed,
  channel.status.changed.
end note

note bottom of idem
  Chống user gửi lặp
  yêu cầu thanh toán nội bộ.
end note

@enduml
