@startuml
title Sequence Diagram - Rút tiền - Tổng quát luồng dữ liệu
autonumber
autoactivate on
hide footbox

skinparam maxMessageSize 220
skinparam ParticipantPadding 36
skinparam defaultFontSize 18
skinparam sequence {
  ActorFontSize 18
  ParticipantFontSize 18
  MessageFontSize 17
  GroupFontSize 17
  ReferenceFontSize 17
}

actor "Creator" as Creator
participant "Frontend" as FE
participant "API Gateway" as GW
participant "Finance Service" as FS

Creator -> FE: Nhập số coin cần rút và thông tin ngân hàng
FE -> GW: Gửi yêu cầu rút tiền
GW -> GW: Kiểm tra phiên đăng nhập

alt Chưa đăng nhập
  GW --> FE: Từ chối yêu cầu
  FE --> Creator: Hiển thị yêu cầu đăng nhập
else Đã đăng nhập
  ref over FE, GW, FS
    Chi tiết 1: Kiểm tra điều kiện rút tiền
  end ref

  GW -> FS: Chuyển tiếp yêu cầu rút tiền
  FS -> FS: Kiểm tra ví, số dư, thông tin ngân hàng và trạng thái payout

  alt Không đủ điều kiện rút tiền
    FS --> GW: Trả thông báo không thể tạo yêu cầu rút tiền
    GW --> FE: Trả kết quả
    FE --> Creator: Hiển thị lỗi rút tiền
  else Đủ điều kiện rút tiền
    ref over FS
      Chi tiết 2: Tạm giữ coin và tạo yêu cầu rút tiền
    end ref

    FS -> FS: Tạm giữ số coin cần rút
    FS -> FS: Tính số tiền thực nhận và phí
    FS -> FS: Tạo yêu cầu rút tiền chờ duyệt
    FS --> GW: Trả thông tin yêu cầu rút tiền
    GW --> FE: Trả kết quả
    FE --> Creator: Hiển thị trạng thái chờ duyệt
  end
end

@enduml
