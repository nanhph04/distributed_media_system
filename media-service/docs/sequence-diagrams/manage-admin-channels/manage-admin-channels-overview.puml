@startuml
title Biểu đồ tuần tự - Khóa kênh (Admin) - Tổng quát
autonumber
autoactivate on
hide footbox

skinparam TitleFontSize 38
skinparam maxMessageSize 260
skinparam ParticipantPadding 90
skinparam defaultFontSize 30
skinparam sequence {
  ActorFontSize 30
  ParticipantFontSize 30
  MessageFontSize 29
  GroupFontSize 29
  ReferenceFontSize 29
}

actor "Admin" as Admin
participant "Frontend" as FE
participant "API Gateway" as GW
participant "Media Service" as MS
queue "Message Broker" as Broker
participant "Finance Service" as FS

Admin -> FE: Chọn khóa kênh và nhập lý do
FE -> GW: Gửi yêu cầu khóa kênh
GW -> GW: Kiểm tra quyền admin

alt Không hợp lệ
  GW --> FE: Từ chối yêu cầu
  FE --> Admin: Hiển thị thông báo
else Hợp lệ
  GW -> MS: Chuyển yêu cầu khóa kênh
  ref over MS
    Chi tiết 1: Media Service khóa kênh và ghi sự kiện
  end ref
  MS --> GW: Trả kết quả khóa kênh
  GW --> FE: Trả kết quả
  FE --> Admin: Hiển thị kênh đã bị khóa

  MS ->> Broker: Phát sự kiện kênh đã đổi trạng thái
  ref over Broker, FS
    Chi tiết 2: Finance Service xử lý payout của kênh
  end ref
end

@enduml
