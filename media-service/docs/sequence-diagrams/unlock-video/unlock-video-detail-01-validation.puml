@startuml
title Biểu đồ tuần tự - Mở khóa video - Chi tiết 1: Kiểm tra điều kiện
autonumber
autoactivate on
hide footbox

skinparam maxMessageSize 220
skinparam ParticipantPadding 36
skinparam defaultFontSize 18
skinparam sequence {
  ActorFontSize 18
  ParticipantFontSize 18
  MessageFontSize 17
  GroupFontSize 17
  ReferenceFontSize 17
}
skinparam BoxPadding 8

actor "Người xem" as Viewer
participant "Frontend" as FE
participant "API Gateway" as GW

box "Media Service" #F5F5F5
  participant "VideosController" as VC
  participant "PurchaseVideoUseCase" as PurchaseUC
  database "Media DB" as DB
end box

Viewer -> FE: Xác nhận mở khóa video
FE -> GW: Gửi yêu cầu mở khóa video
GW -> GW: Kiểm tra phiên đăng nhập

alt Chưa đăng nhập
  GW --> FE: Từ chối yêu cầu
  FE --> Viewer: Hiển thị yêu cầu đăng nhập
else Đã đăng nhập
  GW -> VC: Chuyển tiếp yêu cầu mở khóa
  VC -> PurchaseUC: Xử lý mua video
  PurchaseUC -> DB: Lấy thông tin video

  alt Video không tồn tại
    DB --> PurchaseUC: Không có video
    PurchaseUC --> VC: Trả thông báo video không tồn tại
    VC --> GW: Trả kết quả
    GW --> FE: Trả kết quả
    FE --> Viewer: Hiển thị lỗi
  else Video tồn tại
    DB --> PurchaseUC: Trả thông tin video

    alt Người xem là chủ video
      PurchaseUC --> VC: Từ chối mua video của chính mình
      VC --> GW: Trả kết quả
      GW --> FE: Trả kết quả
      FE --> Viewer: Hiển thị thông báo không hợp lệ
    else Người xem không phải chủ video
      PurchaseUC -> PurchaseUC: Kiểm tra video sẵn sàng, công khai và có thể phát

      alt Video không sẵn sàng để mua
        PurchaseUC --> VC: Trả thông báo video không thể mua
        VC --> GW: Trả kết quả
        GW --> FE: Trả kết quả
        FE --> Viewer: Hiển thị lỗi
      else Video sẵn sàng để mua
        PurchaseUC -> PurchaseUC: Kiểm tra giá video

        alt Video không cần thanh toán
          PurchaseUC --> VC: Trả thông báo video không cần mua
          VC --> GW: Trả kết quả
          GW --> FE: Trả kết quả
          FE --> Viewer: Hiển thị thông báo
        else Video có giá mua
          PurchaseUC -> DB: Kiểm tra người xem đã mở khóa chưa

          alt Đã mở khóa trước đó
            DB --> PurchaseUC: Đã có quyền mở khóa
            PurchaseUC --> VC: Trả kết quả đã mở khóa
            VC --> GW: Trả kết quả
            GW --> FE: Trả kết quả
            FE --> Viewer: Hiển thị video đã mở khóa
          else Chưa mở khóa
            DB --> PurchaseUC: Chưa có quyền mở khóa
            PurchaseUC --> VC: Sẵn sàng chuyển sang thanh toán
          end
        end
      end
    end
  end
end

@enduml
