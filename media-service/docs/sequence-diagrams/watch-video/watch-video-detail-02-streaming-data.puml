@startuml
title Biểu đồ tuần tự - Xem video - Chi tiết 2: Tải playlist và segment
autonumber
autoactivate on
hide footbox

skinparam maxMessageSize 220
skinparam ParticipantPadding 36
skinparam defaultFontSize 18
skinparam sequence {
  ActorFontSize 18
  ParticipantFontSize 18
  MessageFontSize 17
  GroupFontSize 17
  ReferenceFontSize 17
}
skinparam BoxPadding 8

participant "Frontend" as FE
participant "API Gateway" as GW

box "Media Service" #F5F5F5
  participant "StreamingController" as SC
  participant "StreamingUseCase" as StreamUC
  participant "PlaybackTokenService" as Token
  participant "Cache" as Cache
  database "Media DB" as DB
end box

participant "Object Storage" as Storage

== Tải master playlist ==

FE -> GW: Yêu cầu master playlist
GW -> SC: Chuyển tiếp yêu cầu playlist
SC -> StreamUC: Xử lý playlist
StreamUC -> Token: Kiểm tra token phát video

alt Token không hợp lệ
  Token --> StreamUC: Từ chối token
  StreamUC --> SC: Trả kết quả không thể phát
  SC --> GW: Trả kết quả
  GW --> FE: Hiển thị lỗi phát video
else Token hợp lệ
  Token --> StreamUC: Token hợp lệ
  StreamUC -> Cache: Tìm master playlist key

  alt Chưa có trong cache
    Cache --> StreamUC: Không có dữ liệu
    StreamUC -> DB: Lấy master playlist key
    DB --> StreamUC: Trả master playlist key
    StreamUC -> Cache: Lưu master playlist key
  else Có trong cache
    Cache --> StreamUC: Trả master playlist key
  end

  StreamUC -> Cache: Tìm playlist đã gắn token

  alt Chưa có playlist cache
    Cache --> StreamUC: Không có playlist
    StreamUC -> Storage: Đọc playlist gốc
    Storage --> StreamUC: Trả playlist gốc
    StreamUC -> StreamUC: Gắn token vào đường dẫn segment
    StreamUC -> Cache: Lưu playlist đã gắn token
  else Có playlist cache
    Cache --> StreamUC: Trả playlist đã gắn token
  end

  StreamUC --> SC: Trả playlist
  SC --> GW: Trả playlist
  GW --> FE: Trả playlist cho trình phát
end

== Tải segment trong khi xem ==

loop Mỗi lần trình phát cần thêm dữ liệu
  FE -> GW: Yêu cầu segment hoặc playlist con
  GW -> SC: Chuyển tiếp yêu cầu streaming
  SC -> StreamUC: Xử lý dữ liệu phát
  StreamUC -> Token: Kiểm tra token phát video

  alt Token không hợp lệ
    Token --> StreamUC: Từ chối token
    StreamUC --> SC: Trả kết quả không thể phát
    SC --> GW: Trả kết quả
    GW --> FE: Hiển thị lỗi phát video
  else Token hợp lệ
    Token --> StreamUC: Token hợp lệ

    alt Là playlist con
      StreamUC -> Storage: Đọc playlist con
      Storage --> StreamUC: Trả playlist con
      StreamUC -> StreamUC: Gắn token vào playlist con
      StreamUC --> SC: Trả playlist con
    else Là segment media
      StreamUC -> Storage: Đọc segment video
      Storage --> StreamUC: Trả stream segment
      StreamUC --> SC: Trả segment video
    end

    SC --> GW: Trả dữ liệu phát
    GW --> FE: Trả dữ liệu cho trình phát
  end
end

@enduml
